---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostFooter from '@components/post/PostFooter.astro';
import { getReadingTime } from '@utils/posts';
import { useTranslations } from '@utils/i18n';
import type { TocItem } from '@utils/toc';
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  date: Date;
  updated?: Date;
  categories: string[];
  tags: string[];
  authors: string[];
  image?: string;
  description?: string;
  toc: TocItem[];
  slug: string;
  body: string;
  prevPost?: CollectionEntry<'posts'> | null;
  nextPost?: CollectionEntry<'posts'> | null;
  relatedPosts?: CollectionEntry<'posts'>[];
}

const {
  title, date, updated, categories, tags, authors,
  image, description, toc, slug, body,
  prevPost, nextPost, relatedPosts,
} = Astro.props;

const t = useTranslations(Astro.currentLocale);
const minutes = getReadingTime(body);
const catLabel = categories[0] ?? '';
---
<BaseLayout title={title} description={description} image={image} toc={toc}>
  <article class="article-page">
    <header class="article-page-head">
      {catLabel && <p class="article-page-cat">{catLabel}</p>}
      <h1 class="article-page-title">{title}</h1>
      <p class="article-session">
        <span class="prompt">$</span>
        <span> cat </span>
        <span class="arg">posts/{slug}.md</span>
        <span class="flag"> --render</span>
      </p>
      <div class="article-info">
        <span class="article-info-item">
          <time datetime={date.toISOString()}>{date.toISOString().slice(0, 10)}</time>
        </span>
        {updated && (
          <span class="article-info-item">{t('post.updated')} {updated.toISOString().slice(0, 10)}</span>
        )}
        <span class="article-info-item">{authors.join(', ')}</span>
        <span class="article-info-item">{minutes} {t('post.min_read')}</span>
      </div>
    </header>

    {image && (
      <div class="post-hero">
        <img src={image} alt={title} loading="lazy" style="max-width:100%;border-radius:var(--radius);border:1px solid var(--border);display:block;" />
      </div>
    )}

    <div class="prose">
      <slot />
    </div>

    <PostFooter
      slug={slug}
      categories={categories}
      tags={tags}
      prevPost={prevPost}
      nextPost={nextPost}
      relatedPosts={relatedPosts}
    />
  </article>
</BaseLayout>
