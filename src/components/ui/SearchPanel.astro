---
// SearchPanel — uses Pagefind JS API; all DOM construction avoids innerHTML
---

<div id="search-panel" class="search-panel" hidden role="dialog" aria-modal="true" aria-label="搜索">
  <div class="search-panel-head">
    <span>搜索结果</span>
    <button id="search-close" class="search-close" aria-label="关闭搜索">Esc</button>
  </div>
  <div id="search-results" class="search-results"></div>
  <div class="search-panel-foot">
    <span><kbd class="mini">↑↓</kbd> 导航</span>
    <span><kbd class="mini">↵</kbd> 打开</span>
    <span><kbd class="mini">Esc</kbd> 关闭</span>
  </div>
</div>

<script>
(() => {
  const panel     = document.getElementById('search-panel') as HTMLElement | null;
  const resultsEl = document.getElementById('search-results') as HTMLElement | null;
  const input     = document.getElementById('search-input') as HTMLInputElement | null;
  const closeBtn  = document.getElementById('search-close');

  if (!panel || !resultsEl) return;

  function openPanel() {
    panel!.removeAttribute('hidden');
    input?.focus();
  }
  function closePanel() {
    panel!.setAttribute('hidden', '');
    clearResults();
  }
  function clearResults() {
    while (resultsEl!.firstChild) resultsEl!.removeChild(resultsEl!.firstChild);
  }

  closeBtn?.addEventListener('click', closePanel);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closePanel(); return; }
    if ((e.key === '/' || (e.key === 'k' && (e.metaKey || e.ctrlKey))) && !e.isComposing) {
      e.preventDefault();
      openPanel();
    }
  });

  input?.addEventListener('click', openPanel);
  document.getElementById('search-trigger')?.addEventListener('click', openPanel);

  // Close when clicking outside the panel
  document.addEventListener('click', e => {
    const target = e.target as Node;
    if (panel && !panel.hasAttribute('hidden') && !panel.contains(target) && target !== input) {
      closePanel();
    }
  });

  // Lazy-load Pagefind
  let pagefind: Record<string, (...args: unknown[]) => unknown> | null = null;

  async function ensurePagefind() {
    if (pagefind) return pagefind;
    try {
      // @ts-expect-error pagefind is generated at build time
      pagefind = await import('/pagefind/pagefind.js') as Record<string, (...args: unknown[]) => unknown>;
      (pagefind.init as () => void)();
    } catch {
      pagefind = null;
    }
    return pagefind;
  }

  function buildResultNode(r: Record<string, unknown>): HTMLAnchorElement {
    const a = document.createElement('a');
    a.className = 'search-result';
    a.href = String(r.url ?? '/');

    const meta = r.meta as Record<string, string> | undefined;

    if (meta?.category) {
      const metaDiv = document.createElement('div');
      metaDiv.className = 'search-result-meta';
      const catSpan = document.createElement('span');
      catSpan.className = 'sr-cat';
      catSpan.textContent = meta.category;
      metaDiv.appendChild(catSpan);
      a.appendChild(metaDiv);
    }

    const titleDiv = document.createElement('div');
    titleDiv.className = 'search-result-title';
    titleDiv.textContent = meta?.title ?? '';
    a.appendChild(titleDiv);

    const excerptDiv = document.createElement('div');
    excerptDiv.className = 'search-result-excerpt';
    excerptDiv.textContent = String(r.excerpt ?? '');
    a.appendChild(excerptDiv);

    return a;
  }

  function buildEmptyNode(q: string): HTMLElement {
    const div = document.createElement('div');
    div.className = 'search-empty';
    div.textContent = `没有找到 "${q}" 的结果`;
    return div;
  }

  let debounceTimer = 0;

  input?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = window.setTimeout(async () => {
      const q = input!.value.trim();
      clearResults();
      if (!q) return;
      openPanel();
      const pf = await ensurePagefind();
      if (!pf) { resultsEl!.appendChild(buildEmptyNode(q)); return; }
      const res = await (pf.search as (q: string) => Promise<{ results: unknown[] }>)(q);
      const top = await Promise.all(
        res.results.slice(0, 8).map((r: unknown) => (r as { data: () => Promise<Record<string, unknown>> }).data()),
      );
      if (top.length === 0) { resultsEl!.appendChild(buildEmptyNode(q)); return; }
      top.forEach(r => resultsEl!.appendChild(buildResultNode(r)));
    }, 200);
  });
})();
</script>
