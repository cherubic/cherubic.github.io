---
import SearchPanel from '@components/ui/SearchPanel.astro';
import { useTranslations } from '@utils/i18n';

interface Props { currentPath: string; }
const { currentPath } = Astro.props;
const t = useTranslations(Astro.currentLocale);

const segments = currentPath.split('/').filter(Boolean);
const crumbs: Array<{ label: string; href: string }> = [];
let acc = '';
for (const seg of segments) {
  acc += '/' + seg;
  crumbs.push({ label: seg, href: acc });
}
---

<div class="topbar">
  <button class="mobile-toggle" id="mobile-toggle" aria-label="打开菜单">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
      <rect y="2"  width="16" height="2" rx="1"/>
      <rect y="7"  width="16" height="2" rx="1"/>
      <rect y="12" width="16" height="2" rx="1"/>
    </svg>
  </button>

  <nav class="breadcrumb" aria-label="面包屑">
    <a href="/">~</a>
    {crumbs.map((crumb, i) => (
      <>
        <span class="sep">/</span>
        {i < crumbs.length - 1
          ? <a href={crumb.href}>{crumb.label}</a>
          : <span class="crumb-current">{crumb.label}</span>
        }
      </>
    ))}
  </nav>

  <span class="topbar-pill">{t('topbar.deploy')}</span>

  <div class="search-wrap">
    <div class="search-box" aria-label="搜索">
      <input
        type="text"
        id="search-input"
        placeholder={t('topbar.search')}
        autocomplete="off"
        aria-autocomplete="list"
        aria-controls="search-panel"
        aria-expanded="false"
      />
      <kbd class="search-kbd">⌘K</kbd>
    </div>
    <SearchPanel
      msgAll={t('search.all')}
      msgEmptyPre={t('search.empty_pre')}
      msgEmptySuf={t('search.empty_suf')}
      searchHref={Astro.currentLocale === 'en' ? '/en/search' : '/search'}
    />
  </div>
</div>
