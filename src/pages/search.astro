---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="搜索">
  <div class="page-head">
    <p class="page-kicker">$ grep -r</p>
    <h1 class="page-title">搜索</h1>
  </div>

  <div class="search-page">
    <div class="search-page-box">
      <input
        id="search-page-input"
        type="text"
        placeholder="输入关键词…"
        autocomplete="off"
        class="search-page-input"
      />
    </div>
    <div id="search-page-results" class="search-page-results"></div>
  </div>
</BaseLayout>

<script>
(() => {
  const input   = document.getElementById('search-page-input') as HTMLInputElement | null;
  const results = document.getElementById('search-page-results') as HTMLElement | null;
  if (!input || !results) return;

  // Pre-fill from ?q=
  const q0 = new URLSearchParams(location.search).get('q') ?? '';
  if (q0) { input.value = q0; input.focus(); }

  let pagefind: Record<string, (...args: unknown[]) => unknown> | null = null;

  async function ensurePagefind() {
    if (pagefind) return pagefind;
    try {
      // @ts-expect-error pagefind is generated at build time
      pagefind = await import('/pagefind/pagefind.js') as Record<string, (...args: unknown[]) => unknown>;
      (pagefind.init as () => void)();
    } catch { pagefind = null; }
    return pagefind;
  }

  function clearResults() {
    while (results!.firstChild) results!.removeChild(results!.firstChild);
  }

  function buildCard(r: Record<string, unknown>): HTMLElement {
    const meta = r.meta as Record<string, string> | undefined;

    const a = document.createElement('a');
    a.className = 'sp-card';
    a.href = String(r.url ?? '/');

    const title = document.createElement('div');
    title.className = 'sp-title';
    title.textContent = meta?.title ?? String(r.url);
    a.appendChild(title);

    const excerpt = document.createElement('div');
    excerpt.className = 'sp-excerpt';
    excerpt.textContent = String(r.excerpt ?? '');
    a.appendChild(excerpt);

    return a;
  }

  function buildEmpty(q: string): HTMLElement {
    const div = document.createElement('div');
    div.className = 'sp-empty';
    div.textContent = `没有找到 "${q}" 的结果`;
    return div;
  }

  async function runSearch(q: string) {
    clearResults();
    if (!q) return;

    // Update URL without reload
    const url = new URL(location.href);
    url.searchParams.set('q', q);
    history.replaceState(null, '', url.toString());

    const pf = await ensurePagefind();
    if (!pf) { results!.appendChild(buildEmpty(q)); return; }

    const res = await (pf.search as (q: string) => Promise<{ results: unknown[] }>)(q);
    if (res.results.length === 0) { results!.appendChild(buildEmpty(q)); return; }

    const all = await Promise.all(
      res.results.map((r: unknown) => (r as { data: () => Promise<Record<string, unknown>> }).data()),
    );
    all.forEach(r => results!.appendChild(buildCard(r)));
  }

  let timer = 0;
  input.addEventListener('input', () => {
    clearTimeout(timer);
    timer = window.setTimeout(() => runSearch(input.value.trim()), 150);
  });

  if (q0) runSearch(q0);
})();
</script>

<style>
.search-page { padding: 12px 0 80px; }
.search-page-box {
  margin-bottom: 24px;
  position: relative;
}
.search-page-input {
  width: 100%;
  padding: 12px 16px;
  font-family: var(--font-mono);
  font-size: 15px;
  color: var(--ink);
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  outline: none;
  transition: border-color 0.12s;
}
.search-page-input::placeholder { color: var(--muted-2); }
.search-page-input:focus { border-color: var(--rule); }

.search-page-results { display: flex; flex-direction: column; gap: 10px; }

.sp-card {
  display: block;
  padding: 14px 16px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--surface);
  text-decoration: none;
  color: inherit;
  transition: border-color 0.12s, transform 0.1s;
}
.sp-card:hover { border-color: var(--rule); transform: translateX(4px); }
.sp-title {
  font-size: 15px;
  font-weight: 600;
  font-family: var(--font-mono);
  color: var(--ink);
  margin-bottom: 6px;
  line-height: 1.35;
}
.sp-excerpt {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.sp-empty {
  padding: 60px 0;
  text-align: center;
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--muted);
}
</style>
