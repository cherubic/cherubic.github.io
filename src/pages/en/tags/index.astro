---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getPopularTags } from '@utils/posts';
import { useTranslations } from '@utils/i18n';

const t = useTranslations(Astro.currentLocale);
const tags = await getPopularTags(200);
---
<BaseLayout title={t('tags.title')}>
  <div class="page-head">
    <p class="page-kicker">ls ~/tags</p>
    <h1 class="page-title">{t('tags.title')}</h1>
    <p class="page-subtitle">{tags.length} {t('tags.count')}</p>
  </div>

  <div class="tag-cloud-big">
    {tags.map(({ tag, count }) => (
      <a href={`/en/tags/${tag}`} class="tag-big">
        <span class="tc-name">{tag}</span>
        <span class="tc-count">{count}</span>
      </a>
    ))}
  </div>
</BaseLayout>
