---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCard from '@components/ui/ArticleCard.astro';
import { getSortedPosts, paginatePosts } from '@utils/posts';
import { useTranslations } from '@utils/i18n';

const t = useTranslations(Astro.currentLocale);
const allPosts = await getSortedPosts();
const { posts, totalPages } = paginatePosts(allPosts, 1, 10);
---
<BaseLayout title={t('home.title')}>
  <div class="page-head">
    <p class="page-kicker">ls ~/posts</p>
    <h1 class="page-title">{t('home.title')}</h1>
    <p class="page-subtitle">{allPosts.length} {t('home.posts')}</p>
  </div>

  <div class="article-list">
    {posts.map(post => <ArticleCard post={post} />)}
  </div>

  {totalPages > 1 && (
    <nav class="pagination" aria-label="pagination">
      <a href="/en/page/2" class="page-btn">{t('page.next')}</a>
    </nav>
  )}
</BaseLayout>
