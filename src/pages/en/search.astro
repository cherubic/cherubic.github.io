---
import BaseLayout from '@layouts/BaseLayout.astro';
import { useTranslations } from '@utils/i18n';

const t = useTranslations(Astro.currentLocale);
---
<BaseLayout title={t('search.title')}>
  <div class="page-head">
    <p class="page-kicker">grep -r</p>
    <h1 class="page-title">{t('search.title')}</h1>
  </div>

  <div class="search-page">
    <div class="search-page-box">
      <input
        id="search-page-input"
        type="text"
        placeholder={t('search.placeholder')}
        autocomplete="off"
        class="search-page-input"
        data-empty-pre={t('search.empty_pre')}
        data-empty-suf={t('search.empty_suf')}
      />
    </div>
    <div id="search-page-results" class="search-page-results"></div>
  </div>
</BaseLayout>

<script>
(() => {
  const input   = document.getElementById('search-page-input') as HTMLInputElement | null;
  const results = document.getElementById('search-page-results') as HTMLElement | null;
  if (!input || !results) return;

  const q0 = new URLSearchParams(location.search).get('q') ?? '';
  if (q0) { input.value = q0; }

  let pagefindReady: Promise<Record<string, (...args: unknown[]) => unknown> | null> | null = null;

  function loadPagefind() {
    if (pagefindReady) return pagefindReady;
    pagefindReady = (async () => {
      try {
        // @ts-expect-error pagefind is generated at build time
        const pf = await import('/pagefind/pagefind.js') as Record<string, (...args: unknown[]) => unknown>;
        await (pf.init as () => Promise<void>)();
        return pf;
      } catch {
        return null;
      }
    })();
    return pagefindReady;
  }

  loadPagefind();

  function clearResults() {
    while (results!.firstChild) results!.removeChild(results!.firstChild);
  }

  function buildCard(r: Record<string, unknown>): HTMLElement {
    const meta = r.meta as Record<string, string> | undefined;
    const a = document.createElement('a');
    a.className = 'sp-card';
    a.href = String(r.url ?? '/');

    const title = document.createElement('div');
    title.className = 'sp-title';
    title.textContent = meta?.title ?? String(r.url);
    a.appendChild(title);

    const excerpt = document.createElement('div');
    excerpt.className = 'sp-excerpt';
    excerpt.textContent = String(r.excerpt ?? '');
    a.appendChild(excerpt);

    return a;
  }

  function buildEmpty(q: string): HTMLElement {
    const emptyPre = input?.dataset.emptyPre ?? '';
    const emptySuf = input?.dataset.emptySuf ?? '';
    const div = document.createElement('div');
    div.className = 'sp-empty';
    div.textContent = `${emptyPre} "${q}"${emptySuf ? ' ' + emptySuf : ''}`;
    return div;
  }

  async function runSearch(q: string) {
    clearResults();
    if (!q) return;
    const url = new URL(location.href);
    url.searchParams.set('q', q);
    history.replaceState(null, '', url.toString());

    const pf = await loadPagefind();
    if (!pf) { results!.appendChild(buildEmpty(q)); return; }

    const res = await (pf.search as (q: string) => Promise<{ results: unknown[] }>)(q);
    if (res.results.length === 0) { results!.appendChild(buildEmpty(q)); return; }

    const all = await Promise.all(
      res.results.map((r: unknown) => (r as { data: () => Promise<Record<string, unknown>> }).data()),
    );
    all.forEach(r => results!.appendChild(buildCard(r)));
  }

  let timer = 0;
  input.addEventListener('input', () => {
    clearTimeout(timer);
    timer = window.setTimeout(() => runSearch(input.value.trim()), 150);
  });

  if (q0) {
    input.focus();
    runSearch(q0);
  }
})();
</script>
