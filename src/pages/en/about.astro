---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getSortedPosts, getPopularTags } from '@utils/posts';
import { useTranslations } from '@utils/i18n';

const t = useTranslations(Astro.currentLocale);
const posts = await getSortedPosts();
const tags  = await getPopularTags(200);
const totalPosts  = posts.length;
const firstYear   = posts.at(-1)?.data.date.getFullYear() ?? new Date().getFullYear();
const yearsActive = new Date().getFullYear() - firstYear + 1;
---
<BaseLayout title={t('nav.about')}>
  <div class="about-page">
    <div class="about-hero">
      <div class="about-avatar">X</div>
      <div>
        <h1 class="about-name">xander</h1>
        <p class="about-role">{t('about.role')}</p>
        <div class="about-links">
          <a href="https://github.com/cherubic" class="about-link" target="_blank" rel="noopener noreferrer">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.6 0 0 3.6 0 8c0 3.5 2.3 6.5 5.5 7.6.4.1.5-.2.5-.4v-1.4c-2.2.5-2.7-1.1-2.7-1.1-.4-.9-.9-1.2-.9-1.2-.7-.5.1-.5.1-.5.8.1 1.2.8 1.2.8.7 1.2 1.9.9 2.3.7.1-.5.3-.9.5-1.1-1.8-.2-3.6-.9-3.6-4 0-.9.3-1.6.8-2.1-.1-.2-.4-1 .1-2.1 0 0 .7-.2 2.2.8.6-.2 1.3-.3 2-.3s1.4.1 2 .3c1.5-1 2.2-.8 2.2-.8.4 1.1.2 1.9.1 2.1.5.6.8 1.3.8 2.1 0 3.1-1.9 3.8-3.7 4 .3.3.6.8.6 1.6v2.3c0 .2.1.5.5.4C13.7 14.5 16 11.5 16 8c0-4.4-3.6-8-8-8z"/></svg>
            GitHub
          </a>
          <a href="mailto:copyrightcherubic@gmail.com" class="about-link">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M1 3h14v1L8 9 1 4V3zm0 2.5l7 4.5 7-4.5V13H1V5.5z"/></svg>
            Email
          </a>
          <a href="/feed.xml" class="about-link">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><circle cx="3" cy="13" r="1.5"/><path d="M2 7.5A6.5 6.5 0 0 1 8.5 14" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M2 3.5A10.5 10.5 0 0 1 12.5 14" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
            RSS
          </a>
        </div>
      </div>
    </div>

    <div class="about-facts">
      <div class="about-fact">
        <div class="fact-num">{totalPosts}</div>
        <div class="fact-label">POSTS</div>
      </div>
      <div class="about-fact">
        <div class="fact-num">{yearsActive}</div>
        <div class="fact-label">YEARS</div>
      </div>
      <div class="about-fact">
        <div class="fact-num">{tags.length}</div>
        <div class="fact-label">TAGS</div>
      </div>
    </div>

    <div class="prose">
      <p>{t('about.intro')}</p>
      <p>{t('about.contact_pre')} <a href="https://github.com/cherubic/cherubic.github.io/issues" target="_blank" rel="noopener noreferrer">GitHub Issue</a> {t('about.contact_suf')}</p>
    </div>
  </div>
</BaseLayout>
